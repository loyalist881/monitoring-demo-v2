{
  "title": "Bulk Loading Monitor",
  "uid": "bulk-load-dashboard",
  "panels": [
    {
      "title": "JVM Heap Memory (Bytes)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "jvm_memory_used_bytes{area=\"heap\"}", "refId": "A"}]
    },
    {
      "title": "Bulk Load Operations (Custom)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "app_bulk_load_total", "refId": "B"}]
    },
    {
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (status) (http_server_requests_seconds_count)", "refId": "C"}]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "time": {"from": "now-15m", "to": "now"}
}